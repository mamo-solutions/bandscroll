NODE_ENV=development
# Required for Docker deployments. Use the immutable release build ID, e.g. 1.15.5+<git-sha>.
BUILD_ID=development-local
PORT=3000
ADMIN_PASSWORD=change-me-now
ADMIN_SESSION_SECRET=please-change-this-to-a-long-random-secret
UPLOAD_DIR=../uploads
PUBLIC_BASE_URL=http://localhost:3000
# Storage backend: "memory" (default, zero-config), "file" (sessions.json in
# DATA_DIR) or "sqlite" (sessions.db in DATA_DIR, durable per-write).
STORAGE=memory
DATA_DIR=../data
AI_CONFIG_ENCRYPTION_KEY=change-this-ai-encryption-key
# Logging verbosity: debug | info (default) | warn | error.
LOG_LEVEL=info
# Periodic performance-stats summary line interval in ms (0 disables).
METRICS_INTERVAL_MS=60000
