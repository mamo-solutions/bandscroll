{
  "name": "bandscroll-server",
  "version": "1.15.6",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "scripts": {
    "predev": "node scripts/verify-node-version.js && node ../scripts/sync-version.mjs --apply && node scripts/version.js",
    "dev": "tsx watch src/index.ts",
    "prebuild": "node scripts/verify-node-version.js && node ../scripts/sync-version.mjs --apply && node scripts/version.js",
    "build": "tsc -p tsconfig.json",
    "prestart": "node scripts/verify-node-version.js && node ../scripts/sync-version.mjs --apply && node scripts/version.js",
    "start": "node dist/index.js",
    "load:test": "tsx scripts/load-test.ts",
    "pretest": "node scripts/verify-node-version.js && node ../scripts/sync-version.mjs --apply && node scripts/version.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.1",
    "better-sqlite3": "^12.11.1",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^6.0.227",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.13.3",
    "@types/session-file-store": "^1.2.6",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
